# FlowLens environment variables — copy to .env.local and fill in real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# AI provider (leave unset to use the built-in mock provider)
OPENAI_API_KEY=
AI_PROVIDER=mock
